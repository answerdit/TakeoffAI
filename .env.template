# Environment — TakeoffAI
# Copy this to .env and fill in your values

# ── Anthropic ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── App ────────────────────────────────────
APP_ENV=development
API_KEY=
# API_PORT=8000

# ── CORS (required when APP_ENV != development) ──
# ALLOWED_ORIGINS=https://app.takeoffai.ai

# ── Agent defaults ─────────────────────────
# DEFAULT_OVERHEAD_PCT=20
# DEFAULT_MARGIN_PCT=12
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Wiki ──────────────────────────────────────
# WIKI_MODEL=claude-haiku-4-5

# ── Harness Evolver ──────────────────────────
# HARNESS_EVOLVER_MODEL=claude-sonnet-4-6
# HARNESS_EVOLVER_MAX_TOOL_CALLS=30

# ── Google Workspace (gws CLI) ────────────────────
# Install: brew install googleworkspace-cli
# Auth:    gws auth login -s gmail,calendar,sheets
#
# GWS_ENABLED=false
# GWS_BIN=gws                       # full path if gws is not on $PATH
# GWS_NOTIFY_EMAIL=you@example.com  # recipient for all job notifications
# GWS_CALENDAR_ID=primary           # calendar for bid deadline events
# GWS_TOURNAMENT_SHEET_ID=          # Google Sheet ID for tournament log
# GWS_PRICE_AUDIT_SHEET_ID=         # Google Sheet ID for price audit flags
